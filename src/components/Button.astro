---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'white';
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { href, variant = 'primary', class: className = '', size = 'md' } = Astro.props;

const sizeClasses = {
  sm: 'px-5 py-2.5 text-sm',
  md: 'px-7 py-3.5 text-base',
  lg: 'px-8 py-4 text-lg',
};

const variantClasses = {
  primary: 'bg-med-blue text-white hover:bg-blue-600 hover:shadow-blue-glow',
  secondary: 'border-2 border-med-blue text-med-blue hover:bg-med-blue hover:text-white hover:shadow-blue-glow',
  white: 'bg-white text-dark hover:shadow-soft-lg',
};
---

{href ? (
  <a
    href={href}
    class:list={[
      'inline-flex items-center justify-center gap-2.5 font-semibold rounded-xl transition-all duration-300 ease-out active:scale-[0.97]',
      variantClasses[variant],
      sizeClasses[size],
      className,
    ]}
  >
    <slot />
  </a>
) : (
  <button
    class:list={[
      'inline-flex items-center justify-center gap-2.5 font-semibold rounded-xl transition-all duration-300 ease-out active:scale-[0.97]',
      variantClasses[variant],
      sizeClasses[size],
      className,
    ]}
  >
    <slot />
  </button>
)}
