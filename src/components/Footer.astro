---
const quickLinks = [
  { label: 'Partenaires', href: '/partenaires' },
  { label: 'Parrainage', href: '/parrainage' },
  { label: 'Nos tarifs', href: '/tarifs' },
  { label: 'MedActu', href: '/medactu' },
];

const usefulLinks = [
  { label: 'Prenez rendez-vous', href: '/rdv' },
  { label: 'Contact', href: '/rdv' },
  { label: 'Mentions légales', href: '/mentions-legales' },
  { label: 'Données personnelles', href: '/donnees-personnelles' },
];

const socials = [
  { label: 'Facebook', href: 'https://www.facebook.com/medemprunt', icon: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z' },
  { label: 'Instagram', href: 'https://www.instagram.com/medemprunt', icon: 'M16 4H8a4 4 0 00-4 4v8a4 4 0 004 4h8a4 4 0 004-4V8a4 4 0 00-4-4zm-4 11a3 3 0 110-6 3 3 0 010 6zm3.5-6.5a.75.75 0 110-1.5.75.75 0 010 1.5z' },
  { label: 'LinkedIn', href: 'https://fr.linkedin.com/company/medemprunt', icon: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z' },
];
---

<footer class="gradient-bg text-white">
  <div class="container-custom py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-5">
          <img src="/images/logo-medemprunt-white.svg" alt="MedEmprunt" class="h-9 w-auto" />
        </a>
        <p class="text-gray-400 text-sm leading-relaxed">
          Courtier en crédit immobilier spécialisé pour les professions médicales.
        </p>
        <p class="text-gray-500 text-xs mt-5">
          Medemprunt reverse chaque année 3% de son chiffre d'affaire aux associations de jeunes médecins.
        </p>
      </div>

      <!-- Liens Rapides -->
      <div>
        <h3 class="font-display font-bold text-lg text-white/90 mb-5">
          Liens Rapides
        </h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 text-sm hover:text-white transition-colors duration-200 flex items-center gap-2.5">
                <span class="w-1 h-1 rounded-full bg-med-blue/60 flex-shrink-0"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Liens Utiles -->
      <div>
        <h3 class="font-display font-bold text-lg text-white/90 mb-5">
          Liens Utiles
        </h3>
        <ul class="space-y-3">
          {usefulLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 text-sm hover:text-white transition-colors duration-200 flex items-center gap-2.5">
                <span class="w-1 h-1 rounded-full bg-med-blue/60 flex-shrink-0"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-display font-bold text-lg text-white/90 mb-5">
          Entrer en Contact
        </h3>
        <div class="space-y-3">
          <a href="tel:0177624481" class="flex items-center gap-3 text-gray-400 text-sm hover:text-white transition-colors duration-200 bg-white/5 rounded-xl px-4 py-3">
            <svg class="w-4 h-4 text-med-blue flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            01 77 62 44 81
          </a>
          <a href="mailto:contact@medemprunt.fr" class="flex items-center gap-3 text-gray-400 text-sm hover:text-white transition-colors duration-200 bg-white/5 rounded-xl px-4 py-3">
            <svg class="w-4 h-4 text-med-blue flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            contact@medemprunt.fr
          </a>
        </div>

        <!-- Socials -->
        <div class="flex items-center gap-3 mt-6">
          {socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 hover:bg-white/15 transition-all duration-300"
            >
              <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="divider-gradient mt-14 mb-8"></div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-xs">&copy; {new Date().getFullYear()} MedEmprunt. Tous droits réservés.</p>
      <p class="text-gray-500 text-xs">Courtier en opérations de banque et services de paiement — ORIAS n° 22005252</p>
    </div>
  </div>
</footer>
