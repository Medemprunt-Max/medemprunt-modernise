---
interface Props {
  variant?: 'dark' | 'light';
}

const { variant = 'dark' } = Astro.props;

const navLinks = [
  { label: 'Partenaires', href: '/partenaires' },
  { label: 'Parrainage', href: '/parrainage' },
  { label: 'Nos tarifs', href: '/tarifs' },
  { label: 'Espace client', href: '/espace-client' },
  { label: 'À vos côtés', href: '/a-vos-cotes' },
];

const currentPath = Astro.url.pathname;
const isLight = variant === 'light';
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
  data-variant={variant}
>
  <div
    id="header-bg"
    class:list={[
      'transition-all duration-500',
      isLight ? 'header-light' : 'gradient-bg glass bg-opacity-95',
    ]}
  >
    <div class="container-custom">
      <div class="flex items-center justify-between h-18 md:h-22">
        <!-- Logo -->
        <a href="/" class="flex items-center group relative">
          <img
            src="/images/logo-medemprunt.svg"
            alt="MedEmprunt"
            class:list={[
              'h-8 md:h-10 w-auto transition-all duration-500 group-hover:scale-105',
              isLight ? 'logo-dark opacity-100' : 'logo-dark opacity-0 absolute',
            ]}
          />
          <img
            src="/images/logo-medemprunt-white.svg"
            alt="MedEmprunt"
            class:list={[
              'h-8 md:h-10 w-auto transition-all duration-500 group-hover:scale-105',
              isLight ? 'logo-white opacity-0 absolute' : 'logo-white opacity-100',
            ]}
          />
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-1">
          {navLinks.map((link) => {
            const isActive = currentPath === link.href || currentPath === link.href + '/';
            return (
              <a
                href={link.href}
                class:list={[
                  'nav-link px-3 xl:px-4 py-2 text-sm font-medium rounded-lg transition-all duration-300',
                  isActive ? 'nav-link-active' : '',
                  !isLight && isActive && 'text-white bg-white/15',
                  !isLight && !isActive && 'text-gray-300 hover:text-white hover:bg-white/10',
                  isLight && isActive && 'text-dark bg-gray-100/80',
                  isLight && !isActive && 'text-gray-600 hover:text-dark hover:bg-gray-100/60',
                ]}
              >
                {link.label}
              </a>
            );
          })}
        </nav>

        <!-- CTA + Mobile toggle -->
        <div class="flex items-center gap-3">
          <a
            href="/rdv"
            class:list={[
              'cta-btn hidden sm:inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold rounded-xl transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]',
              isLight ? 'bg-med-blue text-white hover:bg-blue-600 hover:shadow-blue-glow' : 'bg-white text-dark hover:shadow-soft-lg',
            ]}
          >
            RDV VISIO GRATUIT
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </a>

          <!-- Mobile hamburger -->
          <button
            id="mobile-menu-btn"
            class:list={[
              'mobile-btn lg:hidden p-2 rounded-lg transition-colors',
              isLight ? 'text-dark hover:bg-gray-100' : 'text-white hover:bg-white/10',
            ]}
            aria-label="Menu"
          >
            <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden">
    <div class="gradient-bg glass border-t border-white/10 px-4 pb-6 pt-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block px-4 py-3 text-sm font-medium rounded-lg transition-colors',
            currentPath === link.href || currentPath === link.href + '/'
              ? 'text-white bg-white/15'
              : 'text-gray-300 hover:text-white hover:bg-white/10',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/rdv"
        class="mt-4 flex items-center justify-center gap-2 px-5 py-3 bg-white text-dark text-sm font-semibold rounded-xl transition-all duration-300 hover:shadow-soft-lg"
      >
        RDV VISIO GRATUIT
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
      </a>
    </div>
  </div>
</header>

<!-- Spacer -->
<div class="h-18 md:h-22"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  // Header scroll behavior with light/dark variant support
  const header = document.getElementById('main-header');
  const headerBg = document.getElementById('header-bg');
  const isLightVariant = header?.dataset.variant === 'light';

  const logoDark = headerBg?.querySelector('.logo-dark') as HTMLElement | null;
  const logoWhite = headerBg?.querySelector('.logo-white') as HTMLElement | null;

  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 80;

    if (isLightVariant) {
      if (scrolled) {
        headerBg?.classList.add('header-scrolled');
        headerBg?.classList.remove('header-light');
        header?.classList.add('shadow-soft-xl');
        // Swap logos: show white, hide dark
        if (logoDark) { logoDark.style.opacity = '0'; }
        if (logoWhite) { logoWhite.style.opacity = '1'; }
      } else {
        headerBg?.classList.remove('header-scrolled');
        headerBg?.classList.add('header-light');
        header?.classList.remove('shadow-soft-xl');
        // Swap logos: show dark, hide white
        if (logoDark) { logoDark.style.opacity = '1'; }
        if (logoWhite) { logoWhite.style.opacity = '0'; }
      }
    } else {
      // Default dark variant behavior
      if (scrolled) {
        header?.classList.add('shadow-soft-xl');
        headerBg?.classList.add('bg-opacity-98');
      } else {
        header?.classList.remove('shadow-soft-xl');
        headerBg?.classList.remove('bg-opacity-98');
      }
    }
  });
</script>
