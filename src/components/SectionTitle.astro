---
interface Props {
  title: string;
  highlight?: string;
  subtitle?: string;
  centered?: boolean;
}

const { title, highlight, subtitle, centered = true } = Astro.props;
---

<div class:list={['mb-14 md:mb-20', centered && 'text-center']}>
  <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-extrabold text-dark leading-tight">
    {title}
    {highlight && <span class="gradient-text"> {highlight}</span>}
  </h2>
  {subtitle && (
    <p class:list={['mt-5 text-gray-500 text-lg md:text-xl leading-relaxed', centered && 'max-w-2xl mx-auto']}>
      {subtitle}
    </p>
  )}
</div>
