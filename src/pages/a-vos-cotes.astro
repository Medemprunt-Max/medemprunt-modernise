---
import Layout from '../layouts/Layout.astro';
import HeroCompact from '../components/HeroCompact.astro';
import Section from '../components/Section.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Button from '../components/Button.astro';

const events = [
  {
    icon: '🎯',
    title: 'Cibles de fléchettes',
    description: 'Chez Medemprunt, nous chouchoutons les professions médicales ! C\'est pour cela que nous vous offrons une cible de fléchettes à mettre en salle de garde pour partager un moment de convivialité et décompresser des journées intenses !',
    cta: 'Remplissez le formulaire pour recevoir gratuitement une cible de fléchette pour votre salle de garde.',
  },
  {
    icon: '🍕',
    title: 'Améliorés en salle de garde',
    description: 'Envie de te régaler et de partager un moment sympa en salle de garde ? Medemprunt s\'occupe de tout ! Viens discuter de tes projets immobiliers avec nos conseillers autour d\'un bon repas et de boissons, dans une ambiance conviviale.',
    cta: 'Tu peux réserver ton amélioré dans la salle de garde et l\'hôpital de ton choix, et on s\'occupe du reste !',
  },
  {
    icon: '🍸',
    title: 'Afterworks',
    description: 'Envie de discuter de ton projet immobilier tout en décompressant de ta journée ? Contacte-nous pour réserver ton afterwork dans le lieu de ton choix, à deux pas de ton hôpital !',
    cta: null,
  },
  {
    icon: '🎉',
    title: 'Soirées internes',
    description: 'Organisateur d\'une soirée interne ou associative, c\'est l\'occasion de se retrouver et de décompresser après de longues journées. Chez Medemprunt, on adore soutenir ces moments de convivialité en vous offrant des goodies pour égayer vos événements !',
    cta: null,
  },
];
---

<Layout title="À vos côtés" description="MedEmprunt à vos côtés : événements, fléchettes en salle de garde, améliorés, afterworks, sponsoring de thèses et soutien aux associations.">
  <HeroCompact
    title="Les événements"
    highlight="Medemprunt"
    subtitle="Échanger, avancer et parler projet immobilier. Nous créons des moments privilégiés pour vous permettre de souffler et avancer dans vos projets !"
  />

  <!-- Événements Grid -->
  <Section>
    <SectionTitle
      title="Nos"
      highlight="événements"
      subtitle="Chez Medemprunt, nous savons que concilier carrière médicale et projets personnels peut être intense. C'est pourquoi nous avons créé des moments privilégiés pour vous."
    />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {events.map((event, i) => (
        <div class="reveal bg-white rounded-2xl border border-gray-100 p-8 card-hover" style={`transition-delay: ${i * 100}ms`}>
          <span class="text-4xl mb-4 block">{event.icon}</span>
          <h3 class="font-display text-xl font-bold text-dark mb-3">{event.title}</h3>
          <p class="text-gray-500 leading-relaxed mb-4">{event.description}</p>
          {event.cta && (
            <p class="text-med-blue text-sm font-medium">{event.cta}</p>
          )}
        </div>
      ))}
    </div>
  </Section>

  <!-- Sponsoring thèses -->
  <Section bg="gray">
    <div class="max-w-4xl mx-auto">
      <div class="reveal grid grid-cols-1 md:grid-cols-2 gap-0 bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-lg">
        <div class="gradient-bg p-8 md:p-12 flex flex-col justify-center">
          <span class="inline-block px-3 py-1 bg-white/10 text-med-blue text-xs font-semibold rounded-full uppercase tracking-wider mb-4">
            Nouveau
          </span>
          <h3 class="font-display text-2xl md:text-3xl font-bold text-white mb-4">
            Nous sponsorisons vos thèses !
          </h3>
          <p class="text-gray-300 leading-relaxed">
            Parce que nous savons qu'organiser une thèse, c'est autant de stress que de moments inoubliables, Medemprunt vous donne un coup de pouce pour le restaurant !
          </p>
        </div>
        <div class="p-8 md:p-12 flex flex-col justify-center">
          <p class="text-gray-500 leading-relaxed mb-6">
            En échange d'une petite présentation de nos services durant l'événement, nous contribuons à rendre ce moment encore plus convivial et réussi. C'est simple, sympa et gagnant-gagnant : vous fêtez votre thèse et nous vous aidons sur le budget, vos invités découvrent comment Medemprunt peut les accompagner dans leurs projets immobiliers.
          </p>
          <p class="text-gray-600 font-medium text-sm">
            Envie de faire parrainer votre thèse ? Contactez-nous à
            <a href="mailto:marketing@medemprunt.fr" class="text-med-blue hover:underline">marketing@medemprunt.fr</a>
          </p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Associations -->
  <Section>
    <div class="max-w-3xl mx-auto text-center">
      <div class="reveal">
        <div class="w-20 h-20 rounded-2xl bg-blue-50 flex items-center justify-center mx-auto mb-8">
          <svg class="w-10 h-10 text-med-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
        </div>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-dark mb-6">
          Nous soutenons aussi les <span class="gradient-text">associations d'internes</span> !
        </h2>
        <p class="text-gray-500 text-lg leading-relaxed mb-8">
          Medemprunt reverse chaque année 3% de ses bénéfices aux associations médicales. Contactez-nous par mail pour en savoir plus.
        </p>
        <Button href="mailto:marketing@medemprunt.fr" variant="primary" size="lg">
          Devenir partenaire
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>
      </div>
    </div>
  </Section>

  <!-- Contact Marketing -->
  <Section bg="dark">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
        Contacte notre équipe <span class="gradient-text">Communication</span>
      </h2>
      <p class="text-gray-300 text-lg mb-6">
        Pour toutes questions ou pour réserver un événement avec nous, contacte notre équipe !
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="mailto:marketing@medemprunt.fr" class="btn-primary text-lg">
          marketing@medemprunt.fr
        </a>
      </div>
      <div class="flex items-center justify-center gap-4 mt-8">
        <a href="https://www.facebook.com/medemprunt" target="_blank" rel="noopener" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white/10 hover:bg-white/20 transition-colors">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        </a>
        <a href="https://www.instagram.com/medemprunt" target="_blank" rel="noopener" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white/10 hover:bg-white/20 transition-colors">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5"/></svg>
        </a>
      </div>
    </div>
  </Section>
</Layout>
