---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Espace Client" description="Accédez à votre espace client MedEmprunt pour suivre l'avancement de votre dossier de prêt immobilier.">
  <!-- Full-page centered content -->
  <section class="min-h-[70vh] flex items-center justify-center relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute inset-0 bg-gradient-to-br from-gray-50 via-blue-50/30 to-white pointer-events-none"></div>
    <div class="absolute -top-32 -right-32 w-96 h-96 bg-med-blue/5 rounded-full blur-3xl animate-pulse-soft"></div>
    <div class="absolute -bottom-32 -left-32 w-72 h-72 bg-accent/5 rounded-full blur-3xl animate-pulse-soft" style="animation-delay: 2s"></div>

    <div class="container-custom relative text-center py-20">
      <div class="max-w-xl mx-auto">
        <!-- Icon -->
        <div class="w-24 h-24 rounded-3xl bg-gradient-to-br from-med-blue to-accent flex items-center justify-center mx-auto mb-10 shadow-blue-glow-lg">
          <svg class="w-12 h-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>

        <h1 class="font-display text-3xl md:text-5xl font-extrabold text-dark mb-5">
          Espace <span class="gradient-text">Client</span>
        </h1>
        <p class="text-gray-500 text-lg mb-12 leading-relaxed">
          Accédez à votre portail client pour suivre l'avancement de votre dossier, consulter vos documents et échanger avec votre conseiller dédié.
        </p>

        <!-- CTA Button -->
        <a
          href="https://medemprunt.fr/rdv/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-8 py-4 bg-med-blue text-white text-lg font-semibold
                 rounded-2xl transition-all duration-300 ease-out hover:bg-blue-600 hover:shadow-blue-glow-lg
                 hover:-translate-y-0.5 active:scale-[0.97]"
        >
          Accéder à mon espace
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>

        <p class="text-gray-400 text-sm mt-8">
          Vous serez redirigé vers notre portail sécurisé
        </p>
      </div>

      <!-- Features mini-cards -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 max-w-2xl mx-auto mt-18">
        <div class="bg-white rounded-xl shadow-soft p-6 text-center card-hover">
          <svg class="w-6 h-6 text-med-blue mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <h3 class="font-semibold text-dark text-sm">Documents</h3>
          <p class="text-gray-400 text-xs mt-1">Consultez vos pièces</p>
        </div>
        <div class="bg-white rounded-xl shadow-soft p-6 text-center card-hover">
          <svg class="w-6 h-6 text-med-blue mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
          <h3 class="font-semibold text-dark text-sm">Suivi dossier</h3>
          <p class="text-gray-400 text-xs mt-1">En temps réel</p>
        </div>
        <div class="bg-white rounded-xl shadow-soft p-6 text-center card-hover">
          <svg class="w-6 h-6 text-med-blue mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <h3 class="font-semibold text-dark text-sm">Messagerie</h3>
          <p class="text-gray-400 text-xs mt-1">Échangez directement</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
