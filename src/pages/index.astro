---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Button from '../components/Button.astro';

const trustBadges = [
  {
    label: 'Service 100% gratuit',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />',
  },
  {
    label: '0€ de frais de dossier',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
  },
  {
    label: 'Disponible 6j/7',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />',
  },
];

const stats = [
  { value: '500', suffix: '+', label: 'Dossiers accompagnés' },
  { value: '0', suffix: '€', label: 'Frais de dossier' },
  { value: '98', suffix: '%', label: 'Taux de satisfaction' },
  { value: '6', suffix: 'j/7', label: 'Disponibilité' },
];

/* Grid size mapping — uses static Tailwind classes so they survive CSS purging */
const gridSizeMap: Record<string, string> = {
  lg: 'md:col-span-7 md:row-span-2',
  md: 'md:col-span-5',
  sm: 'md:col-span-5',
  wide: 'md:col-span-12',
};

const services = [
  {
    title: 'Résidence principale',
    description: 'Vous souhaitez obtenir un crédit immobilier ? Medemprunt négocie votre prêt aux meilleures conditions, adaptées à votre statut médical unique.',
    tag: 'Le plus demandé',
    size: 'lg',
    accent: false,
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />',
    href: '/simulation',
    cta: 'Simuler mon prêt',
  },
  {
    title: 'Installation de cabinet',
    description: "Vous vous installez en libéral ? Nous accompagnons votre projet d'installation avec un financement sur mesure.",
    tag: null,
    size: 'md',
    accent: false,
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />',
    href: '/contact',
    cta: 'En savoir plus',
  },
  {
    title: 'Travaux & rénovation',
    description: "Financez vos travaux énergétiques et d'aménagement aux meilleures conditions du marché.",
    tag: null,
    size: 'sm',
    accent: false,
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />',
    href: '/contact',
    cta: 'En savoir plus',
  },
  {
    title: 'Gestion de patrimoine',
    description: 'Avec Patrimed, protégez votre famille, vos revenus et votre avenir. Conseil patrimonial dédié aux professions médicales.',
    tag: 'Nouveau',
    size: 'wide',
    accent: true,
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />',
    href: '/contact',
    cta: 'Découvrir Patrimed',
  },
];

const engagements = [
  {
    num: '01',
    title: 'Experts des statuts',
    description: 'Nous comprenons vos différents statuts : Interne, CCA, PH, docteur junior, assistant, libéraux en SELARL, SELAS, SCM…',
  },
  {
    num: '02',
    title: 'Humains',
    description: "Fini les chatbots ! Profitez d'un conseiller dédié pour échanger sur vos projets de vie, peu importe la période !",
  },
  {
    num: '03',
    title: 'Disponibles',
    description: "Vos horaires ? Nos horaires ! Nous sommes disponibles en visioconférence, 6j/7 et jusqu'à 23h.",
  },
];
---

<Layout
  title="Courtier crédit immobilier pour médecins, pharmaciens et dentistes"
  description="Courtier spécialisé professions médicales. Obtenez les meilleures conditions de prêt immobilier grâce à nos experts qui comprennent votre statut. Conseil gratuit."
  headerVariant="light"
>
  <!-- ===================== HERO LIGHT & SEARCH ===================== -->
  <section class="hero-light min-h-[85vh] flex flex-col justify-center">
    <!-- Decorative elements -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-40 -right-40 w-[600px] h-[600px] bg-med-blue/[0.06] rounded-full blur-3xl"></div>
      <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] bg-accent/[0.04] rounded-full blur-3xl"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #94a3b8 1px, transparent 1px); background-size: 24px 24px;"></div>
    </div>

    <div class="container-custom relative pt-12 pb-16 md:pt-20 md:pb-24">
      <!-- Trust badges -->
      <div class="flex flex-wrap justify-center gap-3 mb-8 md:mb-10">
        {trustBadges.map((badge) => (
          <span class="trust-badge">
            <svg class="w-4 h-4 text-med-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <Fragment set:html={badge.icon} />
            </svg>
            {badge.label}
          </span>
        ))}
      </div>

      <!-- Heading -->
      <h1 class="text-center font-display text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-dark leading-[1.1] max-w-4xl mx-auto">
        Le prêt immobilier pour les
        <span class="gradient-text"> professionnels de santé</span>
      </h1>

      <!-- Subheading -->
      <p class="text-center mt-6 md:mt-8 text-gray-500 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        Simulez votre emprunt en 30 secondes. Nos experts négocient les meilleures conditions pour votre statut médical.
      </p>

      <!-- Simulation bar -->
      <div class="mt-10 md:mt-14 max-w-3xl mx-auto">
        <form id="sim-form" class="sim-bar">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5 items-end">
            <!-- Montant -->
            <div>
              <label for="sim-amount" class="sim-bar-label">Montant du prêt</label>
              <div class="relative">
                <input
                  id="sim-amount"
                  type="text"
                  inputmode="numeric"
                  placeholder="250 000"
                  class="sim-bar-input pr-10"
                />
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 font-semibold">€</span>
              </div>
            </div>

            <!-- Durée -->
            <div>
              <label for="sim-duration" class="sim-bar-label">Durée</label>
              <select id="sim-duration" class="sim-bar-select">
                <option value="10">10 ans</option>
                <option value="15">15 ans</option>
                <option value="20" selected>20 ans</option>
                <option value="25">25 ans</option>
              </select>
            </div>

            <!-- CTA Button -->
            <div>
              <button type="submit" class="w-full btn-primary py-3.5 text-base rounded-xl font-semibold">
                Simuler mon prêt
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </button>
            </div>
          </div>

          <p class="text-center text-xs text-gray-400 mt-4">
            Gratuit et sans engagement — Résultat en 30 secondes
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- ===================== STATS BANNER ===================== -->
  <section class="stats-banner" id="stats-section">
    <div class="container-custom py-8 md:py-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 text-center">
        {stats.map((stat) => (
          <div class="space-y-1">
            <div class="font-display font-extrabold text-3xl md:text-4xl text-white">
              <span class="stat-value" data-target={stat.value} data-suffix={stat.suffix}>
                {stat.value}{stat.suffix}
              </span>
            </div>
            <p class="text-gray-400 text-sm md:text-base">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES — BENTO GRID ===================== -->
  <Section>
    <SectionTitle
      title="Des solutions"
      highlight="sur mesure"
      subtitle="Des financements adaptés à chaque étape de votre carrière médicale."
    />
    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6">
      {services.map((s) => (
        <div class:list={[
          'bg-white rounded-2xl shadow-soft p-6 md:p-8 card-hover flex flex-col justify-between relative reveal',
          gridSizeMap[s.size] || '',
          s.accent && 'bento-item-accent',
        ]}>
          <div>
            {s.tag && <span class="bento-tag">{s.tag}</span>}
            <div class:list={[
              'w-12 h-12 md:w-14 md:h-14 rounded-xl flex items-center justify-center mb-5',
              s.accent ? 'bg-white/20' : 'bg-blue-50',
            ]}>
              <svg class:list={[
                'w-6 h-6 md:w-7 md:h-7',
                s.accent ? 'text-white' : 'text-med-blue',
              ]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <Fragment set:html={s.icon} />
              </svg>
            </div>
            <h3 class:list={[
              'font-display text-xl md:text-2xl font-bold mb-3',
              s.accent ? 'text-white' : 'text-dark',
            ]}>{s.title}</h3>
            <p class:list={[
              'leading-relaxed',
              s.accent ? 'text-white/80' : 'text-gray-500',
            ]}>{s.description}</p>
          </div>
          <a
            href={s.href}
            class:list={[
              'inline-flex items-center gap-2 mt-6 text-sm font-semibold transition-all duration-300 group/link',
              s.accent ? 'text-white hover:gap-3' : 'text-med-blue hover:gap-3',
            ]}
          >
            {s.cta}
            <svg class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      ))}
    </div>
  </Section>

  <!-- ===================== ENGAGEMENTS ===================== -->
  <Section bg="subtle">
    <SectionTitle
      title="Nos"
      highlight="engagements"
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {engagements.map((e, i) => (
        <div
          class="reveal bg-white rounded-2xl shadow-soft p-8 card-hover border-l-[3px] border-med-blue"
          style={`transition-delay: ${i * 120}ms`}
        >
          <span class="text-5xl font-display font-extrabold gradient-text">{e.num}.</span>
          <h3 class="font-display text-xl font-bold text-dark mt-5 mb-3">{e.title}</h3>
          <p class="text-gray-500 leading-relaxed">{e.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- ===================== CTA FINAL ===================== -->
  <Section bg="dark">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-extrabold text-white mb-6 leading-tight">
        Prêt à obtenir les <span class="gradient-text">meilleures conditions</span> ?
      </h2>
      <p class="text-gray-300 text-lg md:text-xl mb-10 leading-relaxed">
        Prenez rendez-vous gratuitement en visioconférence avec l'un de nos conseillers spécialisés.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/simulation" variant="primary" size="lg">
          Simuler mon prêt
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>
        <Button href="/rdv" variant="white" size="lg">
          RDV Visio Gratuit
        </Button>
      </div>
    </div>
  </Section>
</Layout>

<script>
  // ---- Simulation bar: format amount + redirect to /simulation ----
  const simForm = document.getElementById('sim-form');
  const simAmount = document.getElementById('sim-amount') as HTMLInputElement | null;

  // Format number with spaces (French convention)
  simAmount?.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    const raw = target.value.replace(/\s/g, '').replace(/[^0-9]/g, '');
    if (raw) {
      target.value = parseInt(raw).toLocaleString('fr-FR').replace(/,/g, ' ');
    } else {
      target.value = '';
    }
  });

  // Redirect to simulation page on submit
  simForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    window.location.href = '/simulation';
  });

  // ---- Stats counter animation ----
  function animateValue(el: HTMLElement, target: number, suffix: string, duration: number = 1500) {
    let start = 0;
    const startTime = performance.now();

    function update(currentTime: number) {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      // Ease out cubic
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.floor(eased * target);
      el.textContent = current + suffix;

      if (progress < 1) {
        requestAnimationFrame(update);
      } else {
        el.textContent = target + suffix;
      }
    }

    requestAnimationFrame(update);
  }

  const statsSection = document.getElementById('stats-section');
  let statsAnimated = false;

  const statsObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting && !statsAnimated) {
        statsAnimated = true;
        document.querySelectorAll('.stat-value').forEach((el) => {
          const htmlEl = el as HTMLElement;
          const targetStr = htmlEl.dataset.target || '0';
          const suffix = htmlEl.dataset.suffix || '';
          const targetNum = parseInt(targetStr);

          if (!isNaN(targetNum) && targetNum > 0) {
            animateValue(htmlEl, targetNum, suffix);
          } else {
            // For "0€" — display static value immediately
            htmlEl.textContent = targetStr + suffix;
          }
        });
        statsObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  if (statsSection) {
    statsObserver.observe(statsSection);
  }
</script>
