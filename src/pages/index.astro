---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Button from '../components/Button.astro';

const engagements = [
  {
    num: '01',
    title: 'Experts des statuts',
    description: 'Nous comprenons vos différents statuts : Interne, CCA, PH, docteur junior, assistant, libéraux en SELARL, SELAS, SCM…',
  },
  {
    num: '02',
    title: 'Humains',
    description: 'Fini les chatbots ! Bien qu\'à l\'ère du digital, profitez d\'un conseiller dédié pour échanger sur vos projets de vie, peu importe la période !',
  },
  {
    num: '03',
    title: 'Disponibles',
    description: 'Vos horaires ? Nos horaires ! Nous sommes disponibles en visioconférence, 6j/7 et jusqu\'à 23h.',
  },
];

const services = [
  {
    title: 'Financement de résidence principale',
    description: 'Vous souhaitez obtenir un crédit immobilier ? Medemprunt vous négocie votre prêt aux meilleures conditions !',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />',
  },
  {
    title: 'Financement d\'installation',
    description: 'Vous souhaitez installer votre cabinet en tant que libéral ? Nous vous accompagnons pour obtenir un prêt aux meilleures conditions pour votre installation !',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />',
  },
  {
    title: 'Financement de vos travaux',
    description: 'Nous vous aidons à financer vos travaux énergétiques ! Découvrez dès maintenant les avantages qui vous attendent.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />',
  },
  {
    title: 'Gestion de patrimoine',
    description: 'Avec Patrimed protégez votre famille, vos revenus et votre santé !',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />',
  },
];
---

<Layout
  title="Courtier crédit immobilier pour médecins, pharmaciens et dentistes"
  description="Courtier spécialisé professions médicales. Obtenez les meilleures conditions de prêt immobilier grâce à nos experts qui comprennent votre statut. Conseil gratuit."
>
  <!-- Hero -->
  <section class="relative gradient-bg overflow-hidden flex items-center">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-[700px] h-[700px] bg-med-blue/10 rounded-full blur-3xl animate-pulse-soft"></div>
      <div class="absolute -bottom-40 -left-40 w-[500px] h-[500px] bg-accent/10 rounded-full blur-3xl animate-pulse-soft" style="animation-delay: 2s"></div>
      <div class="absolute top-1/2 left-1/3 w-[900px] h-[900px] bg-white/[0.015] rounded-full"></div>
      <!-- Dot grid -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 32px 32px;"></div>
    </div>

    <div class="container-custom relative pt-24 pb-24 lg:pb-0 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
          L'emprunt pour les médecins,
          <span class="gradient-text italic"> pharmaciens et dentistes</span>
        </h1>
        <p class="mt-8 text-gray-300 text-lg md:text-xl leading-relaxed max-w-lg">
          Notre mission : accompagner les professions médicales pour trouver la meilleure offre de prêt
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <Button href="/simulation" variant="primary" size="lg">
            Simuler un prêt
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
          <Button href="/rdv" variant="white" size="lg">
            RDV Visio Gratuit
          </Button>
        </div>

        <ul class="mt-10 space-y-3">
          <li class="flex items-center gap-3 text-gray-300">
            <div class="w-5 h-5 rounded-full bg-med-blue/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-med-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            dans les meilleures conditions !
          </li>
          <li class="flex items-center gap-3 text-gray-300">
            <div class="w-5 h-5 rounded-full bg-med-blue/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-med-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            en gagnant du temps !
          </li>
          <li class="flex items-center gap-3 text-gray-300">
            <div class="w-5 h-5 rounded-full bg-med-blue/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-med-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            en économisant de l'argent !
          </li>
        </ul>
      </div>

      <div class="hidden lg:flex justify-center">
        <img
          src="https://medemprunt.fr/wp-content/uploads/sites/10/woman-doctor-wearing-lab-coat-with-stethoscope-isolated-609x1024.png"
          alt="Médecin avec stéthoscope"
          class="w-96 h-auto rounded-3xl object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Engagements -->
  <Section bg="subtle">
    <SectionTitle
      title="Nos"
      highlight="engagements"
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {engagements.map((e, i) => (
        <div class="reveal bg-white rounded-2xl shadow-soft p-8 card-hover" style={`transition-delay: ${i * 100}ms`}>
          <span class="text-5xl font-display font-extrabold gradient-text">{e.num}.</span>
          <h3 class="font-display text-xl font-bold text-dark mt-5 mb-3">{e.title}</h3>
          <p class="text-gray-500 leading-relaxed">{e.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Services -->
  <Section>
    <SectionTitle
      title="Nos différents"
      highlight="services"
      subtitle="Des solutions de financement adaptées à chaque étape de votre carrière médicale."
    />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {services.map((s, i) => (
        <div class="reveal bg-white rounded-2xl shadow-soft p-8 card-hover group" style={`transition-delay: ${i * 80}ms`}>
          <div class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-med-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <Fragment set:html={s.icon} />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-dark mb-3">{s.title}</h3>
          <p class="text-gray-500 leading-relaxed">{s.description}</p>
        </div>
      ))}
    </div>
    <div class="text-center mt-14">
      <Button href="/rdv" variant="primary" size="lg">
        Prendre RDV
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </Button>
    </div>
  </Section>
</Layout>
