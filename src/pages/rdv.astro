---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Prendre rendez-vous | MedEmprunt">
  <section class="pt-28 pb-16">
    <div class="container-custom text-center mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Prenez rendez-vous</h1>
      <p class="text-gray-300 text-lg">Réservez votre visio gratuite avec un conseiller MedEmprunt</p>
    </div>
    <div class="container-custom">
      <iframe
        src="https://rdvlgmed.simplybook.it/v2/"
        width="100%"
        height="800"
        frameborder="0"
        class="rounded-2xl bg-white"
        allow="payment"
      ></iframe>
    </div>
  </section>
</Layout>
