---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Prendre rendez-vous | MedEmprunt">
  <section class="section-padding bg-gray-50/80">
    <div class="container-custom text-center mb-12">
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-extrabold text-dark">
        Prenez <span class="gradient-text">rendez-vous</span>
      </h2>
      <p class="text-gray-500 text-lg md:text-xl mt-5 max-w-xl mx-auto">
        Réservez votre visio gratuite avec un conseiller MedEmprunt
      </p>
    </div>
    <div class="container-custom max-w-3xl">
      <!-- Wrapper that clips the top part of the SimplyBook iframe (header/banner) -->
      <div class="sb-wrapper rounded-2xl shadow-soft-lg overflow-hidden bg-white">
        <iframe
          src="https://rdvlgmed.simplybook.it/v2/#book/service/1"
          width="100%"
          height="2000"
          frameborder="0"
          scrolling="no"
          class="sb-iframe"
          allow="payment"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>

<style>
  .sb-wrapper {
    height: 1100px;
    overflow: hidden;
    position: relative;
  }
  .sb-iframe {
    border: none;
    margin-top: -615px;
    position: relative;
  }
</style>
