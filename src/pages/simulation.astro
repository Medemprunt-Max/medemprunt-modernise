---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Simuler un prêt | MedEmprunt">
  <section class="pt-28 pb-16">
    <div class="container-custom text-center mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Simulez votre prêt</h1>
      <p class="text-gray-300 text-lg">Remplissez le formulaire pour obtenir une estimation personnalisée</p>
    </div>
    <div class="container-custom">
      <iframe
        src="https://tally.so/embed/w8eell"
        width="100%"
        height="900"
        frameborder="0"
        class="rounded-2xl bg-white"
      ></iframe>
    </div>
  </section>
</Layout>
