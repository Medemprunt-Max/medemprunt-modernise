---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Simuler un prêt | MedEmprunt">
  <section class="relative gradient-bg overflow-hidden">
    <!-- Decorative -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-32 -right-32 w-[500px] h-[500px] bg-med-blue/10 rounded-full blur-3xl animate-pulse-soft"></div>
      <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-accent/10 rounded-full blur-3xl animate-pulse-soft" style="animation-delay: 2s"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 32px 32px;"></div>
    </div>

    <div class="container-custom relative pt-24 pb-8 text-center">
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-extrabold text-white mb-5">
        Simulez votre <span class="gradient-text">prêt</span>
      </h1>
      <p class="text-gray-300 text-lg md:text-xl max-w-xl mx-auto">Remplissez le formulaire pour obtenir une estimation personnalisée</p>
    </div>
  </section>
  <section class="section-padding bg-gray-50/80">
    <div class="container-custom max-w-3xl">
      <div class="bg-white rounded-2xl shadow-soft-lg p-2">
        <iframe
          src="https://tally.so/embed/w8eell"
          width="100%"
          height="900"
          frameborder="0"
          class="rounded-xl"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>
