---
import Layout from '../layouts/Layout.astro';
import HeroCompact from '../components/HeroCompact.astro';
import Section from '../components/Section.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Button from '../components/Button.astro';

const scenarios = [
  {
    title: 'La banque verse une commission suffisante (1%)',
    result: 'Vous n\'avez rien à nous payer directement.',
    icon: '🎉',
    highlight: true,
  },
  {
    title: 'La banque ne verse pas de commission',
    result: 'Nous vous facturerons la totalité de nos honoraires. Ceci nous permet de travailler avec des banques peu proposées par les courtiers.',
    icon: '📋',
    highlight: false,
  },
  {
    title: 'Cas intermédiaires',
    result: 'Nos honoraires sont ajustés pour vous facturer uniquement la différence de commission, plafonnés à 5 900 €.',
    icon: '⚖️',
    highlight: false,
  },
];

const engagements = [
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />',
    title: 'Objectivité totale',
    description: 'Notre rémunération fixe nous permet de nous focaliser sur un unique objectif : celui de vous conseiller au mieux, en toute objectivité !',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />',
    title: 'Transparence complète',
    description: 'Nous nous engageons à vous envoyer l\'ensemble des offres que nous avons reçues pour votre financement, en vous détaillant les avantages de celle que nous vous conseillons.',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />',
    title: 'Liberté de choix',
    description: 'Vous restez évidemment libre du choix de l\'établissement bancaire avec lequel vous vous engagez, au regard des informations claires et loyales que nous vous avons apportées.',
  },
];
---

<Layout title="Nos Tarifs" description="Tarifs transparents MedEmprunt : 1% du capital emprunté, minimum 1 500 €, maximum 5 900 €. Rémunération juste et objective.">
  <HeroCompact
    title="Nos"
    highlight="Tarifs"
    subtitle="Chez MedEmprunt, nous souhaitons des frais de courtage justes, adaptés à chaque client, et transparents."
  />

  <!-- Explication principale -->
  <Section>
    <div class="max-w-4xl mx-auto">
      <div class="reveal text-center mb-16">
        <p class="text-gray-500 text-lg leading-relaxed mb-8">
          La rémunération du courtier provient de deux sources différentes :
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-blue-50 rounded-2xl p-6 border border-blue-100">
            <div class="w-12 h-12 rounded-xl bg-med-blue/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-med-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="font-display font-bold text-dark text-lg mb-2">La banque</h3>
            <p class="text-gray-500 text-sm">qui peut verser une commission au courtier pour l'apport du client.</p>
          </div>
          <div class="bg-cyan-50 rounded-2xl p-6 border border-cyan-100">
            <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-accent-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="font-display font-bold text-dark text-lg mb-2">Le client</h3>
            <p class="text-gray-500 text-sm">qui peut verser directement des honoraires au courtier pour le travail d'intermédiation et l'accompagnement.</p>
          </div>
        </div>
      </div>

      <!-- Tarif principal -->
      <div class="reveal bg-white rounded-3xl border-2 border-med-blue/20 p-8 md:p-12 text-center shadow-lg shadow-blue-500/5">
        <span class="inline-block px-4 py-1.5 bg-med-blue/10 text-med-blue text-sm font-semibold rounded-full mb-6">
          Rémunération fixe et transparente
        </span>
        <h2 class="font-display text-5xl md:text-7xl font-extrabold gradient-text mb-4">1%</h2>
        <p class="text-gray-600 text-xl mb-6">du capital total emprunté</p>
        <div class="flex items-center justify-center gap-8 text-gray-500">
          <div>
            <span class="block font-display font-bold text-2xl text-dark">1 500 €</span>
            <span class="text-sm">minimum</span>
          </div>
          <div class="w-px h-12 bg-gray-200"></div>
          <div>
            <span class="block font-display font-bold text-2xl text-dark">5 900 €</span>
            <span class="text-sm">maximum</span>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Scénarios -->
  <Section bg="gray">
    <SectionTitle
      title="Comment ça se"
      highlight="répartit ?"
      subtitle="Cette rémunération est partagée entre la banque et le client selon différents scénarios."
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {scenarios.map((scenario, i) => (
        <div
          class:list={[
            'reveal rounded-2xl p-8 card-hover',
            scenario.highlight
              ? 'bg-white border-2 border-med-blue/20 shadow-lg shadow-blue-500/5'
              : 'bg-white border border-gray-100',
          ]}
          style={`transition-delay: ${i * 100}ms`}
        >
          <span class="text-3xl mb-4 block">{scenario.icon}</span>
          <h3 class="font-display text-lg font-bold text-dark mb-3">{scenario.title}</h3>
          <p class="text-gray-500 leading-relaxed text-sm">{scenario.result}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Engagements -->
  <Section>
    <SectionTitle
      title="Nos"
      highlight="engagements"
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {engagements.map((engagement, i) => (
        <div class="reveal text-center" style={`transition-delay: ${i * 100}ms`}>
          <div class="w-16 h-16 rounded-2xl bg-blue-50 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-med-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <Fragment set:html={engagement.icon} />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-dark mb-3">{engagement.title}</h3>
          <p class="text-gray-500 leading-relaxed">{engagement.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- CTA -->
  <Section bg="dark">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-6">
        Prêt à être <span class="gradient-text">accompagné</span> ?
      </h2>
      <p class="text-gray-300 text-lg mb-8">
        Prenez rendez-vous gratuitement en visioconférence avec l'un de nos conseillers.
      </p>
      <Button href="/contact" variant="primary" size="lg">
        RDV VISIO GRATUIT
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
      </Button>
    </div>
  </Section>
</Layout>
